# Git files and directories
.git
.gitignore
.gitattributes

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.code-workspace

# Build artifacts
dist
build

# Dependencies (will be reinstalled in Docker)
node_modules

