# ═══════════════════════════════════════════════════════════════════════════════
# Quantum Messenger Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# IMPORTANT: Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control — it contains secrets!
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server Configuration ──────────────────────────────────────────────────────

# Port the Express server listens on
# Default: 3000
PORT=3000

# Allowed origins for CORS (WebSocket and REST API)
# Use a specific domain in production (e.g., https://yourdomain.com)
# Use '*' only for development
CLIENT_ORIGIN=*

# ─── Supabase Configuration (REQUIRED) ─────────────────────────────────────────
#
# Get these values from: https://app.supabase.com/project/[PROJECT_ID]/settings/api
#

# Supabase project URL
# Example: https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public key (anon key, not the service role key!)
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase service role key (for server-to-server operations)
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ─── Firebase Cloud Messaging Configuration (OPTIONAL) ────────────────────────
#
# Firebase is used for push notifications via FCM.
# Firebase service account is Base64-encoded for secure deployment.
#
# How to set it up:
#   1. Create Firebase project at https://firebase.google.com
#   2. Go to Project Settings → Service Accounts
#   3. Generate new private key (downloads JSON file)
#   4. On Windows: [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-service-account.json"))
#   5. On Linux/Mac: base64 -w 0 firebase-service-account.json
#   6. Paste the Base64 string below
#

FIREBASE_SERVICE_ACCOUNT_BASE64=your-base64-encoded-firebase-service-account-here

# ─── Redis Configuration ──────────────────────────────────────────────────────
#
# Redis is used for:
#   1. Socket.io pub/sub (horizontal scaling)
#   2. Offline message queue (24-hour TTL)
#   3. Future: caching, rate limit counters
#

# Redis connection URL
# Local development: redis://localhost:6379
# Production (e.g., Upstash): redis://:password@host:port
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. Supabase Setup:
#    - Create a Supabase project at https://supabase.com
#    - Go to Settings → API
#    - Copy SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY
#    - Paste them in this file
#
# 2. Firebase Setup (Optional):
#    - Create Firebase project at https://firebase.google.com
#    - Go to Project Settings → Service Accounts
#    - Generate private key (downloads JSON file)
#    - Encode to Base64 and paste above
#
# 3. Redis Setup (Development):
#    - Install Redis: https://redis.io/download
#    - Or use Docker: docker run -d -p 6379:6379 redis:alpine
#
# 4. Redis Setup (Production):
#    - Use Upstash Redis: https://upstash.com
#    - Copy the Redis URL from your Upstash dashboard
#
# 5. Copy this file:
#    cp .env.example .env
#
# 6. Fill in the values above
#
# ═══════════════════════════════════════════════════════════════════════════════
