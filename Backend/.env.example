# Server
PORT=3000

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Redis (used by Socket.io Redis Adapter for horizontal scaling)
REDIS_URL=redis://localhost:6379

# CORS — set to your frontend origin in production (e.g. https://app.example.com)
CLIENT_ORIGIN=*
